# =============================================================================
# Dockerfile.agent — Smoky Python Agent (Jira watcher + LangGraph pipeline)
# =============================================================================
# Referenced by docker-compose.yml (agent + smoky services) but was missing
# from the repo — this fixes that gap. Separate from docker/Dockerfile, which
# builds the Cypress test runner image.
# =============================================================================

FROM python:3.12-slim

WORKDIR /app

# Install dependencies first — Docker layer caching
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy agent + prompts source
COPY agent/ ./agent/
COPY prompts/ ./prompts/

ENV PYTHONUNBUFFERED=1

# Overridden per-service in docker-compose.yml
CMD ["python", "-m", "agent.jira_watcher"]
