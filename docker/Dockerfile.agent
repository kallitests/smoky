# =============================================================================
# Dockerfile.agent — Smoky Python Agent (Jira watcher + LangGraph pipeline)
# =============================================================================
# Also used for the reporting/alerting docker-compose services (they share
# the same Python dependency set — Redis client, Anthropic SDK, requests).
# =============================================================================

FROM python:3.13-slim AS base

WORKDIR /app

# Install dependencies first — Docker layer caching
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy agent + prompts source
COPY agent/ ./agent/
COPY prompts/ ./prompts/

ENV PYTHONUNBUFFERED=1

# Run as non-root
RUN useradd --create-home --uid 1001 smoky \
  && chown -R smoky:smoky /app
USER smoky

# Overridden per-service in docker-compose.yml
CMD ["python", "-m", "agent.jira_watcher"]
