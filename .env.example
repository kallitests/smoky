# =============================================================================
# Smoky — Environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Jira (required)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ
JIRA_SMOKY_LABEL=smoky-ready

# GitHub (required)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=kallitests/smoky-playwright

# Target application URLs (one per environment)
STAGING_BASE_URL=https://staging.yourapp.com
PREPROD_BASE_URL=https://preprod.yourapp.com
PRODUCTION_BASE_URL=https://yourapp.com

# Slack (required)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_CHANNEL=#smoky-results

# Power BI (optional — leave blank to skip)
POWERBI_DATASET_ID=
POWERBI_WORKSPACE_ID=
POWERBI_ACCESS_TOKEN=

# LangSmith observability (optional but recommended)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=smoky-agent
LANGCHAIN_TRACING_V2=true
