# =============================================================================
# Smoky — Environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Jira (required)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ
JIRA_SMOKY_LABEL=smoky-ready

# GitHub (required)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=kallitests/smoky-cypress

# Target application URLs (one per environment)
STAGING_BASE_URL=https://staging.yourapp.com
PREPROD_BASE_URL=https://preprod.yourapp.com
PRODUCTION_BASE_URL=https://yourapp.com

# Slack (required) — real-time, every run
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_CHANNEL=#smoky-results

# Teams (optional — leave blank to skip). Adaptive Card posted to a Power
# Automate "When a Teams webhook request is received" workflow trigger URL —
# real-time, immediate alert on @critical smoke failures only.
TEAMS_WEBHOOK_URL=

# Discord (optional — leave blank to skip). Demo/portfolio channel only —
# never point this at a real production channel. Immediate alert on
# @critical smoke failures only.
DISCORD_WEBHOOK_URL=

# Gmail (optional — leave blank to skip). Batched digest for non-critical/
# regression failures — sent by `docker compose run alerting` /
# `python -m agent.send_digest`, not on every run. Requires a Google
# App Password (not your normal password): myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_DIGEST_TO=qa-team@yourcompany.com

# Redis (required for flakiness tracking + the Gmail digest queue).
# Defaults to the docker-compose `redis` service; point at a managed
# instance in real CI (not a container that dies with the job).
REDIS_URL=redis://localhost:6379/0
FLAKINESS_HISTORY_SIZE=20

# Power BI (optional — leave blank to skip)
POWERBI_DATASET_ID=
POWERBI_WORKSPACE_ID=
POWERBI_ACCESS_TOKEN=

# Cypress Cloud (optional — used by main.yml/nightly.yml for parallel
# sharding + replay/flake analytics; leave blank to run without Cloud)
CYPRESS_RECORD_KEY=

# LangSmith observability (optional but recommended)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=smoky-agent
LANGCHAIN_TRACING_V2=true
